Package: iopr
Type: Package
Title: Inequality of Opportunity Analysis for Complex Surveys
Version: 0.1.0
Authors@R: c(
    person("Francis", "Bilson Darku", email = "fbd17@yahoo.com",
        role = c("aut", "cre"), comment = c(ORCID = "0000-0001-8639-8862")),
